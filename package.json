{
  "name": "incipit",
  "version": "0.1.12",
  "description": "A frontend rework of the official Claude Code VS Code extension — surface redrawn, engine untouched.",
  "bin": {
    "incipit": "bin/cli.js"
  },
  "main": "src/install.js",
  "files": [
    "bin/",
    "src/",
    "companion/",
    "data/",
    "tests/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/cli.js",
    "apply": "node bin/cli.js apply",
    "restore": "node bin/cli.js restore",
    "test": "node tests/patch-contracts.test.js && node tests/cache-history-buckets.test.js && node tests/rerun-handoff.test.js",
    "test:contracts": "node tests/patch-contracts.test.js",
    "test:cache-history": "node tests/cache-history-buckets.test.js",
    "test:rerun-handoff": "node tests/rerun-handoff.test.js"
  },
  "engines": {
    "node": ">=16"
  },
  "os": [
    "win32",
    "darwin",
    "linux"
  ],
  "keywords": [
    "incipit",
    "claude-code",
    "claude",
    "anthropic",
    "vscode",
    "vscode-extension",
    "latex",
    "katex",
    "cjk",
    "typography",
    "markdown",
    "serif",
    "render"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yc-duan/incipit.git"
  },
  "bugs": {
    "url": "https://github.com/yc-duan/incipit/issues"
  },
  "homepage": "https://github.com/yc-duan/incipit#readme",
  "author": "",
  "license": "AGPL-3.0-or-later"
}
