{
  "name": "claude-folder-reference",
  "displayName": "Incipit: Claude Folder Reference",
  "description": "Add a file or folder as an @reference in Claude Code from the explorer context menu.",
  "version": "0.0.4",
  "publisher": "incipit",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "incipitClaudeFolderReference.add",
        "title": "Incipit: Add to Claude Code",
        "icon": "$(mention)",
        "category": "Incipit"
      },
      {
        "command": "incipitClaudeFolderReference.addFromPicker",
        "title": "Incipit: Add to Claude Code…",
        "icon": "$(folder-opened)",
        "category": "Incipit"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "incipitClaudeFolderReference.add",
          "when": "resourceScheme == file || resourceScheme == vscode-remote || resourceScheme == vscode-vfs",
          "group": "navigation@90"
        }
      ]
    },
    "configuration": {
      "title": "Incipit Claude Folder Reference",
      "properties": {
        "incipitClaudeFolderReference.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the 'Add to Claude Code' action on explorer context menus for files and folders."
        }
      }
    }
  }
}
